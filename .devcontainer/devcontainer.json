{
  "name": "Nix Dev Environment",

  // Base Ubuntu image — Nix will be installed on top via feature
  // "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "image": "codercom/enterprise-base:ubuntu",

  "features": {
    // Install Nix package manager inside the container
    "ghcr.io/devcontainers/features/nix:1": {
      "version": "latest",
      "multiUser": true,
      // Enable flakes (modern Nix) and the new CLI
      "extraNixConfig": "experimental-features = nix-command flakes"
    }
  },

  // --privileged is required to run podman (container-in-container)
  "runArgs": ["--privileged"],

  // Runs once after the container is created
  "postCreateCommand": "bash .devcontainer/setup.sh",

  "remoteUser": "vscode",

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
